# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# App URL (for payment links)
NEXT_PUBLIC_APP_URL=http://localhost:3000
STRIPE_CURRENCY=usd

# REQUIRED for single-tenant: fixes Finalize / Mark paid / Write off (bill not found)
# Uncomment and set to your business UUID from Supabase → Table Editor → businesses
# Default platform id: 00000000-0000-0000-0000-000000000001
# PRIMARY_BUSINESS_ID=
